    <draw:frame presentation:style-name="pr25" draw:text-style-name="P31" draw:layer="layout" svg:width="25.199cm" svg:height="17.305cm" svg:x="1.4cm" svg:y="4.314cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-item>
        <text:p xml:id="id15" text:id="id15" text:style-name="P29"><text:span text:style-name="T12">Perguntas devem ser respondidas no prazo</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p xml:id="id16" text:id="id16" text:style-name="P32"><text:span text:style-name="T9">notas decrescentes conforme atrasos</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p xml:id="id17" text:id="id17" text:style-name="P29"><text:span text:style-name="T13">Notas são comparativas</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p xml:id="id18" text:id="id18" text:style-name="P33"><text:span text:style-name="T14">0.0=inferior <text:s/>0.5=média <text:s/>1.0=superior</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p xml:id="id19" text:id="id19" text:style-name="P29"><text:span text:style-name="T12">4 médias, uma para cada conjunto de perguntas</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p xml:id="id20" text:id="id20" text:style-name="P34"><text:span text:style-name="T15">Módulo 1 (x1), Módulo 2 (x1), Módulo 3 (</text:span><text:span text:style-name="T16">x2</text:span><text:span text:style-name="T15">), Módulo 4 (x1)</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p xml:id="id21" text:id="id21" text:style-name="P29"><text:span text:style-name="T17">75% de presença nas aulas</text:span></text:p>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
